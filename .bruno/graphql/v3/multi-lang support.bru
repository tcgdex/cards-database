meta {
  name: multi-lang support
  type: graphql
  seq: 3
}

post {
  url: {{BASE_URL}}/v3/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    cards(filters: {}) {
      id
      locales(langs: ["en", "fr", "de"]) {
        name
        attacks {
          name
          damage
          effect
          cost
        }
        description
      }
    }
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
